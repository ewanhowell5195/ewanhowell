@import "buttons.styl"

.container
  max-width: var(--content-width)
  margin: 0 auto
  min-height: calc(100% - var(--header-height))
  padding: 0 20px
  display: flex
  flex-direction: column

h1
  margin: 0
  padding: 22px 0 0

p
  white-space: pre-wrap

a
  color: var(--color-link-blue)

#output
  padding: 20px 0 40px
  display: flex
  flex-direction: column
  gap: 20px
  align-items: flex-start

canvas
  image-rendering: pixelated

.bed-faces
  display: grid
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr))
  gap: 20px
  width: 100%

.bed-face
  display: flex
  flex-direction: column
  gap: 8px
  background-color: var(--color-grey)
  padding: 12px
  box-shadow: var(--box-shadow)

  h3
    margin: 0
    font-size: 1rem
    word-break: break-all

  canvas
    background-image: url("/assets/images/misc/transparent_dark.webp")
    width: 100%
    height: auto
    max-width: 256px
    align-self: center

.download-all
  align-self: flex-start

.bed-group
  display: flex
  flex-direction: column
  gap: 12px
  width: 100%

  h2
    margin: 0
    word-break: break-all

.errors
  background-color: var(--color-grey)
  padding: 12px 16px
  box-shadow: var(--box-shadow)
  width: 100%

  h2
    margin: 0 0 8px
    font-size: 1.1rem

  ul
    margin: 0
    padding-left: 20px
